# Prevent execution of PHP and other scripts in uploads
Options -Indexes
<FilesMatch "\.(php|phtml|php3|php4|php5|phps|pl|py|jsp|asp|aspx)$">
    Require all denied
</FilesMatch>

# For older Apache versions
<IfModule !mod_authz_core.c>
    <FilesMatch "\.(php|phtml|php3|php4|php5|phps|pl|py|jsp|asp|aspx)$">
        Order Allow,Deny
        Deny from all
    </FilesMatch>
</IfModule>
